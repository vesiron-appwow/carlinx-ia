---
export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'CarLinx — Vehicle Discovery',
  description = 'Discover vehicles for sale worldwide. Search by make, model, price, mileage and more.',
  ogImage = '/icons/og-image.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://carlinx-ia.pages.dev');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#FFA800" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="CarLinx" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <link rel="canonical" href={canonicalURL} />
  <link rel="manifest" href="/manifest.json" />
  <link rel="icon" type="image/png" sizes="32x32" href="/icons/icon-32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/icons/icon-16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/icons/icon-180.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <title>{title}</title>

  <style is:global>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --amber:     #FFA800;
      --amber-d:   #E08F00;
      --amber-glow:rgba(255,168,0,0.12);
      --red:       #E03030;
      --black:     #0C0C0C;
      --dark:      #111318;
      --panel:     #1A1D24;
      --panel-alt: #1E2129;
      --border:    rgba(255,255,255,0.08);
      --text:      #E8E8E8;
      --mute:      #8A8D96;
      --card-bg:   #161921;
      --green:     #34C77B;
      --font-head: 'Barlow Condensed', sans-serif;
      --font-body: 'Barlow', sans-serif;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--font-body);
      background: var(--dark);
      color: var(--text);
      min-height: 100vh;
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
    }

    /* ── OFFLINE BANNER ── */
    #offline-banner {
      display: none;
      position: fixed; top: 0; left: 0; right: 0; z-index: 9999;
      background: var(--red);
      color: white;
      text-align: center;
      padding: 0.6rem 1rem;
      font-family: var(--font-body);
      font-size: 0.875rem;
      font-weight: 600;
    }
    #offline-banner.visible { display: block; }

    /* ── HEADER ── */
    .header {
      position: sticky; top: 0; z-index: 100;
      background: rgba(12,12,12,0.94);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      border-bottom: 1px solid var(--border);
    }
    .header-inner {
      max-width: 1320px; margin: 0 auto;
      display: flex; align-items: center; gap: 1.5rem;
      height: 64px; padding: 0 1.5rem;
    }
    .brand {
      display: flex; align-items: center; gap: 0.6rem;
      text-decoration: none; flex-shrink: 0;
    }
    .brand-mark {
      width: 36px; height: 36px;
      background: var(--amber);
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-family: var(--font-head);
      font-weight: 900; font-size: 1.2rem;
      color: var(--black); letter-spacing: -1px;
    }
    .brand-name {
      font-family: var(--font-head);
      font-weight: 800; font-size: 1.5rem;
      color: white; letter-spacing: 0.02em;
    }
    .brand-name span { color: var(--amber); }

    .header-search {
      flex: 1; max-width: 400px;
      display: flex; align-items: center;
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 0 0.75rem; gap: 0.5rem;
    }
    .header-search svg { color: var(--mute); flex-shrink: 0; }
    .header-search input {
      flex: 1; background: transparent; border: none;
      color: var(--text); font-family: var(--font-body);
      font-size: 0.9rem; padding: 0.6rem 0; outline: none;
    }
    .header-search input::placeholder { color: var(--mute); }

    .header-actions { margin-left: auto; display: flex; gap: 0.625rem; }
    .btn-ghost {
      padding: 0.45rem 1rem; border-radius: 7px;
      border: 1px solid var(--border);
      background: transparent; color: var(--mute);
      font-family: var(--font-body); font-size: 0.85rem; font-weight: 500;
      cursor: pointer; transition: all 0.2s; text-decoration: none;
      display: inline-flex; align-items: center;
    }
    .btn-ghost:hover { border-color: var(--amber); color: var(--amber); }

    /* ── FOOTER ── */
    .footer {
      border-top: 1px solid var(--border);
      padding: 1.5rem 2rem;
      text-align: center;
      color: var(--mute); font-size: 0.82rem;
    }
    .footer a { color: var(--amber); text-decoration: none; }
    .footer a:hover { text-decoration: underline; }
  </style>
</head>
<body>

  <!-- Offline indicator -->
  <div id="offline-banner" role="alert" aria-live="assertive">
    ⚠️ You are offline — showing cached results
  </div>

  <!-- Header -->
  <header class="header">
    <div class="header-inner">
      <a href="/" class="brand" aria-label="CarLinx home">
        <div class="brand-mark" aria-hidden="true">C</div>
        <span class="brand-name">Car<span>Linx</span></span>
      </a>

      <form class="header-search" action="/" method="get" role="search">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input type="search" name="q" placeholder="Search make, model, keyword…" aria-label="Search vehicles" />
      </form>

      <nav class="header-actions" aria-label="Site actions">
        <a href="https://appwow.app" class="btn-ghost" rel="noopener">← AppWow</a>
      </nav>
    </div>
  </header>

  <!-- Page content -->
  <main id="main-content">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="footer">
    <p>
      Powered by <a href="https://appwow.app" rel="noopener">AppWow</a> ·
      Part of the <strong>VTL Evosystem</strong> ·
      CarLinx-IA v1.0
    </p>
  </footer>

  <!-- Service Worker Registration -->
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js')
          .then(reg => console.log('[CarLinx SW] Registered:', reg.scope))
          .catch(err => console.warn('[CarLinx SW] Registration failed:', err));
      });
    }

    // Offline / online detection
    const banner = document.getElementById('offline-banner');
    function updateOnlineStatus() {
      if (banner) banner.classList.toggle('visible', !navigator.onLine);
    }
    window.addEventListener('online',  updateOnlineStatus);
    window.addEventListener('offline', updateOnlineStatus);
    updateOnlineStatus();
  </script>

</body>
</html>

