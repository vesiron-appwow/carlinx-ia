---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getVehicleById, formatPrice, formatMileage } from '../../lib/api';

const { id } = Astro.params;
if (!id) return Astro.redirect('/');

const vehicle = await getVehicleById(id, fetch);

if (!vehicle) {
  return new Response(null, { status: 404 });
}

const specs = [
  { label: 'Make',         value: vehicle.make },
  { label: 'Model',        value: vehicle.model },
  { label: 'Year',         value: String(vehicle.year) },
  { label: 'Fuel',         value: vehicle.fuel },
  { label: 'Transmission', value: vehicle.transmission },
  { label: 'Mileage',      value: `${formatMileage(vehicle.mileage)} miles` },
  { label: 'Body Type',    value: vehicle.body_type },
  { label: 'Colour',       value: vehicle.colour },
  { label: 'Engine',       value: vehicle.engine_size },
  { label: 'Doors',        value: vehicle.doors ? String(vehicle.doors) : undefined },
  { label: 'Location',     value: vehicle.location },
].filter(s => s.value);

const mainImage = vehicle.images?.[0] ?? null;
const galleryImages = vehicle.images?.slice(1) ?? [];
---

<BaseLayout
  title={`${vehicle.title} — CarLinx`}
  description={`${vehicle.year} ${vehicle.make} ${vehicle.model} — ${formatPrice(vehicle.price)} — ${formatMileage(vehicle.mileage)} miles. Listed on CarLinx.`}
  ogImage={mainImage ?? undefined}
>

  <!-- BREADCRUMB -->
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <div class="breadcrumb-inner">
      <a href="/">Vehicles</a>
      <span aria-hidden="true">›</span>
      <a href={`/?make=${encodeURIComponent(vehicle.make)}`}>{vehicle.make}</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">{vehicle.model}</span>
    </div>
  </nav>

  <div class="detail-layout">

    <!-- LEFT: Gallery -->
    <section class="gallery-section" aria-label="Vehicle images">
      <div class="main-image">
        {mainImage
          ? <img src={mainImage} alt={vehicle.title} width="800" height="500" loading="eager" decoding="async" />
          : <div class="image-placeholder" aria-label="No image available">🚗</div>
        }
      </div>
      {galleryImages.length > 0 && (
        <div class="thumb-strip" role="list" aria-label="Additional photos">
          {galleryImages.map((img, i) => (
            <button
              class="thumb"
              role="listitem"
              aria-label={`Photo ${i + 2}`}
              onclick={`setMainImage('${img}')`}
            >
              <img src={img} alt={`${vehicle.title} photo ${i + 2}`} width="120" height="80" loading="lazy" decoding="async" />
            </button>
          ))}
        </div>
      )}
    </section>

    <!-- RIGHT: Info panel -->
    <aside class="info-panel">
      <div class="price-block">
        <div class="detail-price">{formatPrice(vehicle.price)}</div>
        <h1 class="detail-title">{vehicle.year} {vehicle.make} {vehicle.model}</h1>
        <p class="detail-trim">{vehicle.title}</p>
      </div>

      <!-- Key stats -->
      <div class="key-stats">
        <div class="stat">
          <span class="stat-icon">📏</span>
          <span class="stat-val">{formatMileage(vehicle.mileage)}</span>
          <span class="stat-lbl">miles</span>
        </div>
        <div class="stat">
          <span class="stat-icon">⚙️</span>
          <span class="stat-val">{vehicle.fuel}</span>
          <span class="stat-lbl">fuel</span>
        </div>
        <div class="stat">
          <span class="stat-icon">🔄</span>
          <span class="stat-val">{vehicle.transmission}</span>
          <span class="stat-lbl">gearbox</span>
        </div>
        <div class="stat">
          <span class="stat-icon">📍</span>
          <span class="stat-val">{vehicle.location}</span>
          <span class="stat-lbl">location</span>
        </div>
      </div>

      <!-- Contact actions -->
      <div class="contact-actions">
        {vehicle.seller_phone && (
          <a href={`tel:${vehicle.seller_phone}`} class="btn-contact btn-call">
            📞 Call Seller
          </a>
        )}
        <a href={`mailto:?subject=Enquiry: ${encodeURIComponent(vehicle.title)}`} class="btn-contact btn-enquire">
          ✉️ Send Enquiry
        </a>
      </div>

      <!-- Full spec table -->
      <div class="spec-table-wrap">
        <h2 class="section-heading">Full Specification</h2>
        <dl class="spec-table">
          {specs.map(s => (
            <>
              <dt>{s.label}</dt>
              <dd>{s.value}</dd>
            </>
          ))}
        </dl>
      </div>

      <!-- Description -->
      {vehicle.description && (
        <div class="description-wrap">
          <h2 class="section-heading">Description</h2>
          <p class="description">{vehicle.description}</p>
        </div>
      )}

      <!-- Seller -->
      {vehicle.seller_name && (
        <div class="seller-block">
          <span class="seller-label">Listed by</span>
          <span class="seller-name">{vehicle.seller_name}</span>
        </div>
      )}

    </aside>
  </div>

  <!-- Back link -->
  <div class="back-row">
    <a href="/" class="btn-back">← Back to Results</a>
  </div>

</BaseLayout>

<script is:inline>
  function setMainImage(src) {
    const img = document.querySelector('.main-image img');
    if (img) img.src = src;
  }
</script>

<style>
  .breadcrumb {
    border-bottom: 1px solid var(--border);
    padding: 0.75rem 1.5rem;
    background: var(--dark);
  }
  .breadcrumb-inner {
    max-width: 1320px; margin: 0 auto;
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.83rem; color: var(--mute);
  }
  .breadcrumb a { color: var(--mute); text-decoration: none; }
  .breadcrumb a:hover { color: var(--amber); }

  .detail-layout {
    max-width: 1320px; margin: 0 auto;
    padding: 2rem 1.5rem;
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 2rem; align-items: start;
  }

  /* Gallery */
  .main-image {
    background: var(--panel);
    border-radius: 12px; overflow: hidden;
    aspect-ratio: 16/10;
    display: flex; align-items: center; justify-content: center;
  }
  .main-image img {
    width: 100%; height: 100%; object-fit: cover;
  }
  .image-placeholder { font-size: 5rem; }

  .thumb-strip {
    display: flex; gap: 0.625rem; flex-wrap: wrap; margin-top: 0.75rem;
  }
  .thumb {
    width: 90px; height: 62px; border-radius: 7px; overflow: hidden;
    border: 2px solid var(--border); cursor: pointer; background: none;
    padding: 0; transition: border-color 0.2s;
  }
  .thumb:hover { border-color: var(--amber); }
  .thumb img { width: 100%; height: 100%; object-fit: cover; }

  /* Info panel */
  .info-panel {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.75rem;
    display: flex; flex-direction: column; gap: 1.5rem;
    position: sticky; top: 80px;
  }

  .detail-price {
    font-family: var(--font-head); font-weight: 900; font-size: 2.4rem;
    color: var(--amber); line-height: 1;
  }
  .detail-title {
    font-family: var(--font-head); font-weight: 800; font-size: 1.5rem;
    color: white; margin: 0.3rem 0 0.15rem;
  }
  .detail-trim { font-size: 0.9rem; color: var(--mute); }

  .key-stats {
    display: grid; grid-template-columns: 1fr 1fr; gap: 0.875rem;
  }
  .stat {
    background: var(--panel); border-radius: 8px; padding: 0.875rem;
    display: flex; flex-direction: column; gap: 0.2rem;
  }
  .stat-icon { font-size: 1.1rem; }
  .stat-val { font-family: var(--font-head); font-weight: 700; font-size: 1rem; color: white; }
  .stat-lbl { font-size: 0.72rem; color: var(--mute); text-transform: uppercase; letter-spacing: 0.07em; }

  .contact-actions { display: flex; flex-direction: column; gap: 0.625rem; }
  .btn-contact {
    display: block; width: 100%; padding: 0.875rem;
    border-radius: 8px; text-align: center;
    font-family: var(--font-head); font-weight: 700; font-size: 1.05rem;
    text-decoration: none; transition: all 0.2s; letter-spacing: 0.04em;
  }
  .btn-call    { background: var(--amber); color: var(--black); }
  .btn-call:hover { background: var(--amber-d); }
  .btn-enquire {
    background: var(--panel); color: var(--text);
    border: 1px solid var(--border);
  }
  .btn-enquire:hover { border-color: var(--amber); color: var(--amber); }

  .section-heading {
    font-family: var(--font-head); font-weight: 700; font-size: 1rem;
    text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--mute); margin-bottom: 0.875rem;
  }

  .spec-table { display: grid; grid-template-columns: auto 1fr; gap: 0.5rem 1.25rem; }
  .spec-table dt { font-size: 0.83rem; color: var(--mute); }
  .spec-table dd { font-size: 0.9rem; color: var(--text); font-weight: 500; }

  .description { font-size: 0.9rem; color: var(--mute); line-height: 1.7; }

  .seller-block {
    display: flex; align-items: center; gap: 0.625rem;
    padding-top: 0.875rem; border-top: 1px solid var(--border);
    font-size: 0.85rem;
  }
  .seller-label { color: var(--mute); }
  .seller-name  { color: var(--text); font-weight: 600; }

  .back-row {
    max-width: 1320px; margin: 0 auto;
    padding: 0 1.5rem 3rem;
  }
  .btn-back {
    display: inline-block; padding: 0.6rem 1.25rem;
    border: 1px solid var(--border); border-radius: 7px;
    color: var(--mute); text-decoration: none; font-size: 0.875rem;
    transition: all 0.2s;
  }
  .btn-back:hover { border-color: var(--amber); color: var(--amber); }

  @media (max-width: 900px) {
    .detail-layout { grid-template-columns: 1fr; }
    .info-panel { position: static; }
  }
</style>
