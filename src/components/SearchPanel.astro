---
import { MAKES_BY_TYPE, VEHICLE_TYPES, CAR_MAJOR_MAKES, CAR_ALL_MAKES } from '../lib/makes';

export interface Props {
  params?: Record<string, string>;
}

const { params = {} } = Astro.props;

const activeType = (params.type ?? 'car') as 'car' | 'commercial' | 'motorbike';

// Fuel options vary slightly by type
const FUELS: Record<string, string[]> = {
  car:        ['Petrol', 'Diesel', 'Hybrid', 'Plug-in Hybrid', 'Electric', 'LPG', 'Hydrogen', 'Other'],
  commercial: ['Diesel', 'Petrol', 'Electric', 'LPG', 'Hybrid', 'Other'],
  motorbike:  ['Petrol', 'Electric', 'Other'],
};

// Transmission options vary by type
const TRANSMISSIONS: Record<string, string[]> = {
  car:        ['Automatic', 'Manual', 'Semi-Automatic', 'CVT'],
  commercial: ['Manual', 'Automatic', 'Semi-Automatic'],
  motorbike:  ['Manual', 'Automatic', 'Semi-Automatic'],
};

// Body types vary by type
const BODY_TYPES: Record<string, string[]> = {
  car:        ['Saloon', 'Hatchback', 'Estate', 'SUV', 'Coupe', 'Convertible', 'MPV', 'Pickup', 'Other'],
  commercial: ['Panel Van', 'Crew Van', 'Chassis Cab', 'Tipper', 'Curtainsider', 'Box Van', 'Flatbed', 'Minibus', 'HGV', 'Other'],
  motorbike:  ['Naked / Streetfighter', 'Sports / Superbike', 'Tourer', 'Adventure / Enduro', 'Cruiser', 'Scooter / Moped', 'Trials', 'Motocross', 'Classic', 'Other'],
};

const years = Array.from({ length: 35 }, (_, i) => 2025 - i);

// Pre-serialise all makes data for client-side JS switching
const makesData = JSON.stringify({
  car:        MAKES_BY_TYPE.car,
  commercial: MAKES_BY_TYPE.commercial,
  motorbike:  MAKES_BY_TYPE.motorbike,
});

const fuelsData       = JSON.stringify(FUELS);
const transmissionsData = JSON.stringify(TRANSMISSIONS);
const bodyTypesData   = JSON.stringify(BODY_TYPES);
---

<section class="search-section" aria-label="Vehicle search filters">

  <!-- TYPE SELECTOR TABS -->
  <div class="type-tabs" role="tablist" aria-label="Vehicle type">
    {VEHICLE_TYPES.map(t => (
      <button
        role="tab"
        class:list={['type-tab', { active: t.value === activeType }]}
        data-type={t.value}
        aria-selected={t.value === activeType ? 'true' : 'false'}
        onclick={`selectType('${t.value}')`}
        type="button"
      >
        <span class="type-icon" aria-hidden="true">{t.icon}</span>
        <span class="type-label">{t.label}</span>
        <span class="type-desc">{t.desc}</span>
      </button>
    ))}
  </div>

  <!-- SEARCH FORM -->
  <form class="search-panel" method="get" action="/" id="search-form">

    <!-- Hidden type field — populated by JS -->
    <input type="hidden" name="type" id="f-type" value={activeType} />

    <!-- Make -->
    <div class="field">
      <label for="f-make">Make</label>
      <select id="f-make" name="make" onchange="handleMakeChange(this)">
        <option value="">Any Make</option>
        <optgroup label="── Popular ──" id="make-major-group">
          {MAKES_BY_TYPE[activeType].major.map(m => (
            <option value={m} selected={params.make === m}>{m}</option>
          ))}
        </optgroup>
        <optgroup label="── All Makes ──" id="make-all-group">
          {MAKES_BY_TYPE[activeType].all
            .filter(m => !MAKES_BY_TYPE[activeType].major.includes(m))
            .map(m => (
              <option value={m} selected={params.make === m}>{m}</option>
            ))
          }
        </optgroup>
        <option value="__other__">Other / Not Listed</option>
      </select>
      <input
        type="text"
        id="f-make-custom"
        name="make_custom"
        placeholder="Enter make…"
        class="custom-input"
        style="display:none; margin-top:0.4rem;"
        value={params.make_custom ?? ''}
      />
    </div>

    <!-- Model -->
    <div class="field">
      <label for="f-model">Model</label>
      <input id="f-model" type="text" name="model" placeholder="e.g. Transit, R1, A4…" value={params.model ?? ''} />
    </div>

    <!-- Fuel -->
    <div class="field">
      <label for="f-fuel">Fuel</label>
      <select id="f-fuel" name="fuel">
        <option value="">Any</option>
        {FUELS[activeType].map(f => (
          <option value={f.toLowerCase().replace(/ /g,'-')} selected={params.fuel === f.toLowerCase().replace(/ /g,'-')}>{f}</option>
        ))}
      </select>
    </div>

    <!-- Transmission -->
    <div class="field">
      <label for="f-trans">Gearbox</label>
      <select id="f-trans" name="transmission">
        <option value="">Any</option>
        {TRANSMISSIONS[activeType].map(t => (
          <option value={t.toLowerCase().replace(/ /g,'-')} selected={params.transmission === t.toLowerCase().replace(/ /g,'-')}>{t}</option>
        ))}
      </select>
    </div>

    <!-- Body Type -->
    <div class="field">
      <label for="f-body">Body Type</label>
      <select id="f-body" name="body_type">
        <option value="">Any</option>
        {BODY_TYPES[activeType].map(b => (
          <option value={b.toLowerCase().replace(/ \/ /g,'-').replace(/ /g,'-')} selected={params.body_type === b.toLowerCase().replace(/ \/ /g,'-').replace(/ /g,'-')}>{b}</option>
        ))}
      </select>
    </div>

    <!-- Min Price -->
    <div class="field">
      <label for="f-min">Min Price</label>
      <select id="f-min" name="min_price">
        <option value="">No Min</option>
        {[500,1000,2500,5000,7500,10000,15000,20000,25000,30000,40000,50000,75000,100000].map(p => (
          <option value={p} selected={params.min_price === String(p)}>£{p.toLocaleString('en-GB')}</option>
        ))}
      </select>
    </div>

    <!-- Max Price -->
    <div class="field">
      <label for="f-max">Max Price</label>
      <select id="f-max" name="max_price">
        <option value="">No Max</option>
        {[3000,5000,7500,10000,15000,20000,25000,30000,40000,50000,75000,100000,150000,200000].map(p => (
          <option value={p} selected={params.max_price === String(p)}>£{p.toLocaleString('en-GB')}</option>
        ))}
      </select>
    </div>

    <!-- Max Mileage -->
    <div class="field">
      <label for="f-mileage">Max Mileage</label>
      <select id="f-mileage" name="max_mileage">
        <option value="">Any</option>
        {[5000,10000,20000,30000,40000,50000,60000,75000,100000,125000,150000].map(m => (
          <option value={m} selected={params.max_mileage === String(m)}>{m.toLocaleString('en-GB')} mi</option>
        ))}
      </select>
    </div>

    <!-- Year From -->
    <div class="field">
      <label for="f-year">Year From</label>
      <select id="f-year" name="year_from">
        <option value="">Any</option>
        {years.map(y => (
          <option value={y} selected={params.year_from === String(y)}>{y}</option>
        ))}
      </select>
    </div>

    <!-- Location -->
    <div class="field">
      <label for="f-location">Location</label>
      <input id="f-location" type="text" name="location" placeholder="City, postcode, country…" value={params.location ?? ''} />
    </div>

    <!-- Search -->
    <div class="field field-submit">
      <button type="submit" class="btn-search">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        Search
      </button>
    </div>

  </form>
</section>

<!-- All dropdown data baked in at build time, switched client-side -->
<script is:inline define:vars={{ makesData, fuelsData, transmissionsData, bodyTypesData }}>
  const MAKES        = JSON.parse(makesData);
  const FUELS_MAP    = JSON.parse(fuelsData);
  const TRANS_MAP    = JSON.parse(transmissionsData);
  const BODIES_MAP   = JSON.parse(bodyTypesData);

  function slug(s) { return s.toLowerCase().replace(/ \/ /g, '-').replace(/ /g, '-'); }

  function rebuildSelect(selectEl, items, currentVal) {
    const prev = currentVal ?? selectEl.value;
    while (selectEl.options.length > 1) selectEl.remove(1);
    items.forEach(item => {
      const opt = document.createElement('option');
      opt.value = slug(item);
      opt.textContent = item;
      if (slug(item) === prev) opt.selected = true;
      selectEl.appendChild(opt);
    });
  }

  function rebuildMakes(type, currentMake) {
    const makes = MAKES[type];
    const majorGroup = document.getElementById('make-major-group');
    const allGroup   = document.getElementById('make-all-group');
    if (!majorGroup || !allGroup) return;

    // Clear existing options in groups
    majorGroup.innerHTML = '';
    allGroup.innerHTML   = '';

    const majorSet = new Set(makes.major);
    makes.major.forEach(m => {
      const opt = document.createElement('option');
      opt.value = m;
      opt.textContent = m;
      if (m === currentMake) opt.selected = true;
      majorGroup.appendChild(opt);
    });
    makes.all.filter(m => !majorSet.has(m)).forEach(m => {
      const opt = document.createElement('option');
      opt.value = m;
      opt.textContent = m;
      if (m === currentMake) opt.selected = true;
      allGroup.appendChild(opt);
    });
  }

  function selectType(type) {
    // Update hidden field
    document.getElementById('f-type').value = type;

    // Update tab active states
    document.querySelectorAll('.type-tab').forEach(tab => {
      const isActive = tab.dataset.type === type;
      tab.classList.toggle('active', isActive);
      tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
    });

    // Update hero title/eyebrow
    const labels = { car: 'Cars', commercial: 'Commercial', motorbike: 'Motorbikes' };
    const eyebrow = document.querySelector('.hero-eyebrow');
    if (eyebrow) eyebrow.textContent = `Global ${labels[type]} Discovery`;

    // Rebuild makes
    rebuildMakes(type, '');

    // Rebuild fuel
    rebuildSelect(document.getElementById('f-fuel'), FUELS_MAP[type], '');

    // Rebuild transmission
    rebuildSelect(document.getElementById('f-trans'), TRANS_MAP[type], '');

    // Rebuild body type
    rebuildSelect(document.getElementById('f-body'), BODIES_MAP[type], '');

    // Update model placeholder
    const modelPlaceholders = {
      car:        'e.g. Golf, A4, 3 Series…',
      commercial: 'e.g. Transit, Sprinter, Daily…',
      motorbike:  'e.g. R1, CBR, Street Triple…',
    };
    const modelInput = document.getElementById('f-model');
    if (modelInput) modelInput.placeholder = modelPlaceholders[type];
  }

  function handleMakeChange(sel) {
    const custom = document.getElementById('f-make-custom');
    if (!custom) return;
    if (sel.value === '__other__') {
      custom.style.display = 'block';
      custom.required = true;
      custom.focus();
    } else {
      custom.style.display = 'none';
      custom.required = false;
      custom.value = '';
    }
  }

  // Expose globally
  window.selectType     = selectType;
  window.handleMakeChange = handleMakeChange;
</script>

<style>
  /* ── TYPE TABS ── */
  .type-tabs {
    display: flex; gap: 0;
    border-bottom: 1px solid var(--border);
    background: var(--black);
    max-width: 100%;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .type-tabs::-webkit-scrollbar { display: none; }

  .type-tab {
    flex: 1; min-width: 120px;
    display: flex; flex-direction: column; align-items: center; gap: 0.2rem;
    padding: 1rem 1.5rem 0.875rem;
    background: transparent; border: none;
    border-bottom: 3px solid transparent;
    cursor: pointer; transition: all 0.2s;
    position: relative;
  }
  .type-tab:not(:last-child) { border-right: 1px solid var(--border); }

  .type-tab:hover {
    background: rgba(255,168,0,0.04);
  }
  .type-tab.active {
    border-bottom-color: var(--amber);
    background: rgba(255,168,0,0.06);
  }

  .type-icon { font-size: 1.5rem; line-height: 1; }
  .type-label {
    font-family: var(--font-head); font-weight: 700; font-size: 1rem;
    color: var(--mute); letter-spacing: 0.04em;
    transition: color 0.2s;
  }
  .type-tab.active .type-label, .type-tab:hover .type-label { color: white; }
  .type-tab.active .type-label { color: var(--amber); }

  .type-desc {
    font-size: 0.7rem; color: var(--mute);
    text-align: center; line-height: 1.3;
    display: none;
  }
  @media (min-width: 700px) { .type-desc { display: block; } }

  /* ── SEARCH PANEL ── */
  .search-section {
    background: var(--panel);
    border-bottom: 1px solid var(--border);
  }

  .search-panel {
    max-width: 1320px; margin: 0 auto;
    padding: 1.5rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 0.875rem;
    align-items: end;
  }

  .field { display: flex; flex-direction: column; }
  .field label {
    font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--mute); margin-bottom: 0.4rem;
  }
  .field select,
  .field input[type="text"],
  .custom-input {
    width: 100%;
    background: var(--dark);
    border: 1px solid var(--border);
    border-radius: 7px;
    padding: 0.65rem 0.875rem;
    color: var(--text);
    font-family: var(--font-body); font-size: 0.9rem;
    outline: none; appearance: none;
    transition: border-color 0.2s;
  }
  .field select:focus,
  .field input:focus { border-color: var(--amber); }
  .field select option,
  .field select optgroup { background: var(--dark); color: var(--text); }

  .field-submit { justify-content: flex-end; }
  .btn-search {
    width: 100%; padding: 0.7rem 1rem;
    background: var(--amber); color: var(--black);
    border: none; border-radius: 7px;
    font-family: var(--font-head); font-weight: 700; font-size: 1rem;
    letter-spacing: 0.05em; cursor: pointer;
    display: flex; align-items: center; justify-content: center; gap: 0.5rem;
    transition: background 0.2s, transform 0.15s;
  }
  .btn-search:hover { background: var(--amber-d); transform: translateY(-1px); }
  .btn-search:active { transform: translateY(0); }

  @media (max-width: 600px) {
    .search-panel { grid-template-columns: 1fr 1fr; }
    .field-submit { grid-column: 1 / -1; }
  }
</style>
