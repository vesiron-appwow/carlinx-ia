---
import type { Vehicle } from '../lib/api';
import { formatPrice, formatMileage } from '../lib/api';

export interface Props {
  vehicle: Vehicle;
}

const { vehicle } = Astro.props;

const thumb = vehicle.images?.[0] ?? null;
const fuelIcon: Record<string, string> = {
  petrol: '⛽', diesel: '🛢️', hybrid: '🔋', electric: '⚡', other: '⚙️',
};
const fuelEmoji = fuelIcon[(vehicle.fuel ?? '').toLowerCase()] ?? '⚙️';
---

<article class="card" data-id={vehicle.id}>
  <a href={`/vehicle/${vehicle.id}`} class="card-link" aria-label={`View ${vehicle.title}`}>

    <div class="card-thumb">
      {thumb
        ? <img src={thumb} alt={vehicle.title} loading="lazy" decoding="async" width="400" height="220" />
        : <span class="thumb-placeholder" aria-hidden="true">🚗</span>
      }
      <span class="fuel-badge">{fuelEmoji} {vehicle.fuel}</span>
      <button
        class="save-btn"
        aria-label={`Save ${vehicle.title}`}
        data-vehicle-id={vehicle.id}
        onclick="event.preventDefault(); toggleSave(this)"
      >♡</button>
    </div>

    <div class="card-body">
      <div class="card-price">{formatPrice(vehicle.price)}</div>
      <h2 class="card-title">{vehicle.year} {vehicle.make} {vehicle.model}</h2>
      <p class="card-trim">{vehicle.title}</p>

      <dl class="specs">
        <div class="spec">
          <dt class="sr-only">Mileage</dt>
          <dd><span aria-hidden="true">📏</span> <strong>{formatMileage(vehicle.mileage)}</strong> mi</dd>
        </div>
        <div class="spec">
          <dt class="sr-only">Transmission</dt>
          <dd><span aria-hidden="true">🔄</span> <strong>{vehicle.transmission}</strong></dd>
        </div>
        <div class="spec">
          <dt class="sr-only">Year</dt>
          <dd><span aria-hidden="true">📅</span> <strong>{vehicle.year}</strong></dd>
        </div>
        <div class="spec">
          <dt class="sr-only">Location</dt>
          <dd><span aria-hidden="true">📍</span> <strong>{vehicle.location}</strong></dd>
        </div>
      </dl>

      <div class="card-actions">
        <span class="btn-view">View Details →</span>
      </div>
    </div>
  </a>
</article>

<style>
  .card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.25s, border-color 0.25s, box-shadow 0.25s;
  }
  .card:hover {
    transform: translateY(-4px);
    border-color: rgba(255,168,0,0.35);
    box-shadow: 0 16px 40px rgba(0,0,0,0.45), 0 0 0 1px rgba(255,168,0,0.08);
  }
  .card-link {
    display: block; text-decoration: none; color: inherit;
  }

  .card-thumb {
    position: relative;
    height: 200px;
    background: linear-gradient(135deg, #1e2028, #252830);
    overflow: hidden;
    display: flex; align-items: center; justify-content: center;
  }
  .card-thumb img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.4s;
  }
  .card:hover .card-thumb img { transform: scale(1.04); }
  .thumb-placeholder { font-size: 4rem; }
  .card-thumb::after {
    content: '';
    position: absolute; bottom: 0; left: 0; right: 0; height: 50%;
    background: linear-gradient(transparent, rgba(12,12,12,0.55));
  }

  .fuel-badge {
    position: absolute; top: 0.875rem; left: 0.875rem; z-index: 1;
    background: rgba(0,0,0,0.72);
    backdrop-filter: blur(8px);
    border: 1px solid var(--border);
    padding: 0.28rem 0.6rem; border-radius: 5px;
    font-size: 0.72rem; font-weight: 600; color: var(--text);
    letter-spacing: 0.06em; text-transform: uppercase;
  }
  .save-btn {
    position: absolute; top: 0.875rem; right: 0.875rem; z-index: 2;
    width: 34px; height: 34px;
    background: rgba(0,0,0,0.65);
    backdrop-filter: blur(8px);
    border: 1px solid var(--border);
    border-radius: 7px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem; cursor: pointer;
    transition: all 0.2s; color: var(--text);
  }
  .save-btn:hover, .save-btn.saved {
    background: rgba(255,168,0,0.2);
    border-color: var(--amber);
    color: var(--amber);
  }
  .save-btn.saved::before { content: '♥'; }
  .save-btn.saved { font-size: 0; }
  .save-btn.saved::before { font-size: 1rem; }

  .card-body { padding: 1.25rem; }

  .card-price {
    font-family: var(--font-head);
    font-weight: 800; font-size: 1.75rem;
    color: var(--amber); line-height: 1;
    margin-bottom: 0.35rem;
  }
  .card-title {
    font-family: var(--font-head);
    font-weight: 700; font-size: 1.15rem;
    color: white; margin-bottom: 0.15rem;
  }
  .card-trim {
    font-size: 0.82rem; color: var(--mute);
    margin-bottom: 1rem;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }

  .specs {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 0.45rem;
    background: rgba(255,255,255,0.03);
    border-radius: 8px; padding: 0.875rem;
    margin-bottom: 1rem; list-style: none;
  }
  .spec dd {
    font-size: 0.82rem; color: var(--mute);
    display: flex; align-items: center; gap: 0.35rem;
  }
  .spec strong { color: var(--text); font-weight: 500; }

  .card-actions { display: flex; }
  .btn-view {
    width: 100%; padding: 0.75rem;
    background: var(--amber);
    color: var(--black);
    border-radius: 7px;
    font-family: var(--font-head);
    font-weight: 700; font-size: 1rem;
    text-align: center; letter-spacing: 0.04em;
    transition: background 0.2s;
    display: block;
  }
  .card:hover .btn-view { background: var(--amber-d); }
</style>
