---
// components/SearchForm.astro
import { MAKES } from '../lib/makes';

const params = Astro.url?.searchParams ?? new URLSearchParams();
const v = (key: string) => params.get(key) ?? '';
const currentCategory = v('vehicle_category') || 'car';
---

<section class="hero">
  <div class="hero-inner">
    <p class="hero-label">Global Vehicle Discovery</p>
    <h1 class="hero-title">Find Your Next<br><em>Great Drive</em></h1>
    <p class="hero-sub">Search vehicles from private sellers and dealers worldwide.</p>

    <form class="search-panel" method="GET" action="/">

      <!-- VEHICLE CATEGORY -->
      <div class="field">
        <label>Vehicle Type</label>
        <div class="category-selector">
          <button type="button" class={`cat-btn ${currentCategory === 'car' ? 'active' : ''}`} data-category="car">Cars</button>
          <button type="button" class={`cat-btn ${currentCategory === 'commercial' ? 'active' : ''}`} data-category="commercial">Commercial</button>
          <button type="button" class={`cat-btn ${currentCategory === 'motorbike' ? 'active' : ''}`} data-category="motorbike">Motorbikes</button>
        </div>
        <input type="hidden" name="vehicle_category" id="vehicle_category" value={currentCategory} />
      </div>

      <!-- MAKE -->
      <div class="field">
        <label for="make">Make</label>
        <select name="make" id="make">
          <option value="">Any Make</option>

          {currentCategory === 'car' && (
            <>
              <optgroup label="Major Makes">
                {MAKES.car.major.map(m => (
                  <option value={m} selected={v('make') === m}>{m}</option>
                ))}
              </optgroup>
              <optgroup label="All Makes">
                {MAKES.car.all.map(m => (
                  <option value={m} selected={v('make') === m}>{m}</option>
                ))}
              </optgroup>
            </>
          )}

          {currentCategory === 'commercial' && (
            <>
              {MAKES.commercial.map(m => (
                <option value={m} selected={v('make') === m}>{m}</option>
              ))}
            </>
          )}

          {currentCategory === 'motorbike' && (
            <>
              {MAKES.motorbike.map(m => (
                <option value={m} selected={v('make') === m}>{m}</option>
              ))}
            </>
          )}

          <option value="__other__" selected={v('make') === '__other__'}>Other / Not Listed</option>
        </select>

        <input
          type="text"
          name="make_custom"
          id="make_custom"
          placeholder="Enter make…"
          class="make-custom"
          value={v('make_custom')}
          style="display:none; margin-top:0.4rem;"
        />
      </div>

      <!-- MODEL -->
      <div class="field">
        <label for="model">Model</label>
        <input type="text" name="model" id="model" placeholder="e.g. Golf, X5, Corolla…" value={v('model')} />
      </div>

      <!-- MIN PRICE -->
      <div class="field">
        <label for="min_price">Min Price</label>
        <select name="min_price" id="min_price">
          <option value="">No Min</option>
          <option value="1000" selected={v('min_price')==='1000'}>£1,000</option>
          <option value="2500" selected={v('min_price')==='2500'}>£2,500</option>
          <option value="5000" selected={v('min_price')==='5000'}>£5,000</option>
          <option value="10000" selected={v('min_price')==='10000'}>£10,000</option>
          <option value="15000" selected={v('min_price')==='15000'}>£15,000</option>
          <option value="20000" selected={v('min_price')==='20000'}>£20,000</option>
          <option value="30000" selected={v('min_price')==='30000'}>£30,000</option>
          <option value="50000" selected={v('min_price')==='50000'}>£50,000</option>
          <option value="75000" selected={v('min_price')==='75000'}>£75,000</option>
        </select>
      </div>

      <!-- MAX PRICE -->
      <div class="field">
        <label for="max_price">Max Price</label>
        <select name="max_price" id="max_price">
          <option value="">No Max</option>
          <option value="5000" selected={v('max_price')==='5000'}>£5,000</option>
          <option value="10000" selected={v('max_price')==='10000'}>£10,000</option>
          <option value="15000" selected={v('max_price')==='15000'}>£15,000</option>
          <option value="20000" selected={v('max_price')==='20000'}>£20,000</option>
          <option value="30000" selected={v('max_price')==='30000'}>£30,000</option>
          <option value="50000" selected={v('max_price')==='50000'}>£50,000</option>
          <option value="75000" selected={v('max_price')==='75000'}>£75,000</option>
          <option value="100000" selected={v('max_price')==='100000'}>£100,000</option>
          <option value="200000" selected={v('max_price')==='200000'}>£200,000+</option>
        </select>
      </div>

      <!-- LOCATION -->
      <div class="field">
        <label for="location">Location</label>
        <input type="text" name="location" id="location" placeholder="City, region or postcode…" value={v('location')} />
      </div>

      <button type="submit" class="btn-search">Search Vehicles</button>
    </form>
  </div>
</section>

<style>
  .category-selector {
    display: flex;
    gap: 0.5rem;
  }

  .cat-btn {
    flex: 1;
    padding: 0.6rem 0.8rem;
    border-radius: 7px;
    border: 1px solid var(--border);
    background: var(--dark);
    color: var(--text);
    cursor: pointer;
    font-weight: 600;
    transition: all 0.2s ease;
  }

  .cat-btn.active {
    background: var(--amber);
    color: var(--black);
    border-color: var(--amber);
  }

  .cat-btn:hover {
    border-color: var(--amber);
  }
</style>

<script>
  const categoryButtons = document.querySelectorAll('.cat-btn');
  const hiddenCategory = document.getElementById('vehicle_category');

  categoryButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      hiddenCategory.value = btn.dataset.category;
      document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      document.querySelector('form').submit();
    });
  });

  const makeSelect = document.getElementById('make');
  const makeCustom = document.getElementById('make_custom');

  makeSelect?.addEventListener('change', () => {
    const show = makeSelect.value === '__other__';
    makeCustom.style.display = show ? 'block' : 'none';
    if (!show) makeCustom.value = '';
  });

  if (makeSelect?.value === '__other__') {
    makeCustom.style.display = 'block';
  }
</script>