---
// components/Header.astro
---
<header class="header">
  <div class="header-inner">
    <a href="/" class="brand">
      <div class="brand-mark">C</div>
      <span class="brand-name">Car<span>Linx</span></span>
    </a>

    <div class="header-search">
      <span class="search-icon" aria-hidden="true">🔍</span>
      <input
        type="search"
        placeholder="Search make, model, keyword…"
        aria-label="Quick search"
        id="quick-search"
      />
    </div>

    <nav class="header-actions">
      <a href="/" class="btn-ghost">🏠 Home</a>
    </nav>
  </div>
</header>

<style>
  .header {
    position: sticky; top: 0; z-index: 100;
    background: rgba(12,12,12,0.94);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
    padding: 0 2rem;
  }
  .header-inner {
    max-width: 1320px; margin: 0 auto;
    display: flex; align-items: center; gap: 1.5rem;
    height: 64px;
  }
  .brand {
    display: flex; align-items: center; gap: 0.6rem;
    text-decoration: none; flex-shrink: 0;
  }
  .brand-mark {
    width: 36px; height: 36px;
    background: var(--amber);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900; font-size: 1.2rem;
    color: var(--black);
  }
  .brand-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800; font-size: 1.5rem;
    color: white; letter-spacing: 0.02em;
  }
  .brand-name span { color: var(--amber); }

  .header-search {
    flex: 1; max-width: 400px;
    display: flex; align-items: center;
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0 0.75rem; gap: 0.5rem;
  }
  .header-search input {
    flex: 1; background: transparent; border: none;
    color: var(--text); font-family: 'Barlow', sans-serif;
    font-size: 0.9rem; padding: 0.6rem 0; outline: none;
  }
  .header-search input::placeholder { color: var(--mute); }
  .search-icon { color: var(--mute); }

  .header-actions { margin-left: auto; display: flex; gap: 0.75rem; }

  @media (max-width: 640px) {
    .header-search { display: none; }
  }
</style>

<script>
  // Quick search — submits to index with ?q= param
  const qs = document.getElementById('quick-search') as HTMLInputElement;
  qs?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && qs.value.trim()) {
      window.location.href = `/?q=${encodeURIComponent(qs.value.trim())}`;
    }
  });
</script>
